# ============================================
# HayCancha.com — environment variables
# Copy this file to `.env` and fill in real values for local development.
# Production values live in Cloudflare Pages → Settings → Environment variables.
# ============================================

# Directus base URL — required at import time (src/lib/directus.ts will throw).
VITE_DIRECTUS_URL=https://api.haycancha.com

# ── Google AdSense ──
# When VITE_ADSENSE_PUBLISHER_ID is empty, the blog AdSlot markers degrade
# to visual placeholders. No script is loaded.
# When set, AdsenseScript injects adsbygoogle.js and each slot id maps to
# the corresponding <!-- AD_SLOT_N --> marker in editorial content.
VITE_ADSENSE_PUBLISHER_ID=
VITE_ADSENSE_SLOT_1=
VITE_ADSENSE_SLOT_2=
VITE_ADSENSE_SLOT_3=
